# ───────────────────────────────────────────────────────────────
# Aura — Environment Variables
# Copy this file to `.env` and fill in. Defaults below run locally
# with ZERO external accounts (SQLite + mock AI coach).
# ───────────────────────────────────────────────────────────────

# Database — SQLite for instant local dev.
# For production, swap to Postgres (Supabase/Neon) and change the
# datasource provider in prisma/schema.prisma to "postgresql":
#   DATABASE_URL="postgresql://user:pass@host:5432/aura?sslmode=require"
DATABASE_URL="file:./dev.db"

# NextAuth (Auth.js v5)
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me-in-production-please-0000000000"
NEXTAUTH_URL="http://localhost:3000"

# AI Coach — Anthropic (Claude). LEAVE BLANK to use the built-in
# rule-based mock coach (the app stays fully functional in demos).
ANTHROPIC_API_KEY=""
# Model id for the coach. Opus is the flagship; sonnet is cheaper/faster.
AI_COACH_MODEL="claude-opus-4-8"

# Supabase Storage (progress photos). Optional — the app falls back
# to local object URLs / base64 previews when unset.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="progress-photos"
